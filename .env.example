KB_API_KEY=your-opencode-go-api-key
KB_BASE_URL=https://opencode.ai/zen/go/v1
KB_MODEL=kimi-k2.5
# OpenCode Go: use nome simples, sem prefixo (ex.: kimi-k2.5, minimax-2.7, glm-5)

# Diretório de dados do seu vault/corpus local (recomendado fora do repositório do código)
# KB_DATA_DIR=/path/to/your/llm-wiki

# Taxonomia opcional da wiki (separada por vírgulas, sem incluir `general`)
# KB_TOPICS=cybersecurity,ai,python,typescript

# Overrides opcionais por diretório:
# KB_RAW_DIR=/path/to/your/llm-wiki/raw
# KB_WIKI_DIR=/path/to/your/llm-wiki/wiki
# KB_OUTPUTS_DIR=/path/to/your/llm-wiki/outputs
# KB_STATE_DIR=/path/to/your/llm-wiki/kb_state

# Para modelos locais via Ollama, descomente:
# KB_BASE_URL=http://localhost:11434/v1
# KB_API_KEY=ollama
# KB_MODEL=qwen2.5-coder:7b
